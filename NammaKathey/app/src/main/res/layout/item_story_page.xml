<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_white"
    android:padding="16dp">

    <!-- Story Illustration -->
    <ImageView
        android:id="@+id/ivStoryImage"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:src="@drawable/ic_launcher_foreground"
        android:scaleType="centerCrop"
        android:background="@color/district_default"
        android:contentDescription="Story Illustration"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Page Title -->
    <TextView
        android:id="@+id/tvStoryPageTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="The Brave Warrior"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/saffron"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/ivStoryImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Story Text -->
    <TextView
        android:id="@+id/tvStoryText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="Story content goes here..."
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginTop="12dp"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/tvStoryPageTitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>